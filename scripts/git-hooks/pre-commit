#!/usr/bin/env bash
# Pre-commit hook: gofmt + go vet + secret scan
# Install: make install-hooks
set -euo pipefail

staged_go=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' ':!*_test.go')

# ─── 1. gofmt check ──────────────────────────────────────────────
# Check ALL staged .go files (including tests) for formatting issues.
fmt_issues=$(gofmt -l $(git diff --cached --name-only --diff-filter=ACM -- '*.go' 2>/dev/null) 2>/dev/null || true)
if [ -n "$fmt_issues" ]; then
    echo "FAIL: gofmt found unformatted files. Run 'gofmt -w .' and re-stage."
    echo "$fmt_issues" | sed 's/^/  /'
    exit 1
fi

# ─── 2. go vet ───────────────────────────────────────────────────
# Fast static analysis on the whole module.
if ! go vet ./... 2>&1; then
    echo "FAIL: go vet found issues. Fix above errors before committing."
    exit 1
fi

# ─── 3. Secret scan ──────────────────────────────────────────────
# Scan ALL staged files for hardcoded secrets (nsec, api keys, etc.)
# Excludes test files, docs, and known-safe patterns.

# Pattern 1: Nostr nsec (bech32, always starts with nsec1)
nsec_hits=$(git diff --cached --name-only --diff-filter=ACM | xargs grep -l 'nsec1' 2>/dev/null \
    | xargs grep -noE 'nsec1[0-9a-z]{20,}' 2>/dev/null \
    | grep -viE '(test_|fake|dummy|example|placeholder|your_|REPLACE|CHANGE|ROTATE|NEW_NSEC|<nsec)' \
    2>/dev/null || true)
if [ -n "$nsec_hits" ]; then
    echo "FAIL: Hardcoded Nostr nsec detected in staged files:"
    echo "$nsec_hits" | sed 's/^/  /'
    echo ""
    echo "Secrets must go in /etc/tollgate/secrets.env on the server."
    echo "To bypass: git commit --no-verify (only if this is a test fixture)"
    exit 1
fi

# Pattern 2: Generic secrets in non-Go files (configs, YAML, Makefile)
config_secrets=$(git diff --cached --diff-filter=ACM -- '*.yml' '*.yaml' 'Makefile' '*.conf' '*.sh' '*.env' \
    | grep -iE '^\+' \
    | grep -ioE '(TOLLGATE_API_KEY|TOLLGATE_OPERATOR_NSEC)\s*[:=]\s*[A-Za-z0-9+/=_-]{16,}' \
    | grep -viE '(test_|fake|dummy|example|placeholder|xxx|your_|REPLACE|CHANGE|secrets\.env|\$\$|$$)' \
    2>/dev/null || true)
if [ -n "$config_secrets" ]; then
    echo "FAIL: Hardcoded secret in config/build file:"
    echo "$config_secrets" | sed 's/^/  /'
    echo "Move secrets to /etc/tollgate/secrets.env."
    echo "To bypass: git commit --no-verify"
    exit 1
fi

# Pattern 3: Original Go-file secret scan (kept for completeness)
go_secrets=$(git diff --cached -- '*.go' ':!*_test.go' ':!internal/testtoken/' | grep -iE '^\+' \
    | grep -ioE '(api[_-]?key|secret|password|nsec|priv[_-]?key|token)\s*[:=]\s*["'"'"'][A-Za-z0-9+/=_-]{16,}' \
    | grep -viE '(test_|fake|dummy|example|placeholder|xxx|your_|REPLACE|CHANGE)' \
    2>/dev/null || true)
if [ -n "$go_secrets" ]; then
    echo "WARNING: Possible hardcoded secret in Go file:"
    echo "$go_secrets" | sed 's/^/  /'
    echo "If this is a false positive (test fixture), add it to the exclusion list."
    echo "To bypass: git commit --no-verify"
    exit 1
fi

echo "OK: gofmt clean, go vet clean, no secrets detected."

# ─── 4. FreeRADIUS command-injection regression guard ──────────
# If any config/freeradius/ file is staged, fail on `/bin/sh -c` + `%{...}`.
# Prevents reintroducing the original shell-wrapped exec module pattern.
staged_freeradius=$(git diff --cached --name-only --diff-filter=ACM -- 'config/freeradius/*' 2>/dev/null || true)
if [ -n "$staged_freeradius" ]; then
    REPO_ROOT="$(git rev-parse --show-toplevel)"
    if ! "$REPO_ROOT/scripts/check-freeradius-configs.sh" >/dev/null 2>&1; then
        "$REPO_ROOT/scripts/check-freeradius-configs.sh"
        echo "FAIL: command-injection pattern reintroduced in config/freeradius/."
        echo "To bypass: git commit --no-verify (NOT RECOMMENDED — this is a CVE-class fix)"
        exit 1
    fi
fi
