#!/usr/bin/env bash
# Pre-push hook: run unit tests with race detector before pushing.
# Install: make install-hooks
#
# Runs `go test -race ./...` and blocks push on failure.
# To bypass: git push --no-verify
set -euo pipefail

# Only run if there are .go files
if ! git diff --cached --name-only HEAD@{push} 2>/dev/null | grep -q '\.go$'; then
    # Fallback: check if any Go files differ from origin/main
    if ! git diff --name-only origin/main...HEAD 2>/dev/null | grep -q '\.go$'; then
        echo "OK: No Go files changed, skipping tests."
        exit 0
    fi
fi

echo "Running go test -race ./..."
if ! go test -race ./... 2>&1; then
    echo ""
    echo "FAIL: Unit tests failed. Fix above errors before pushing."
    echo "To bypass: git push --no-verify"
    exit 1
fi

echo "OK: All unit tests passed with race detector."
