# /etc/freeradius/3.0/users
# Route payment credentials to exec validation.
# Accepts Cashu tokens (cashuA/cashuB) and LNURL-withdraw (lnurlw/LNURLW).
# All other users are rejected.

# Cashu token in username
DEFAULT User-Name =~ /^cashu[AB]/
    Auth-Type := Accept,
    Exec-Program-Wait = "/usr/local/bin/tollgate-auth-radius '%{User-Name}' '%{Calling-Station-Id}' '%{User-Password}'"

# Cashu token in password (TTLS+PAP path)
DEFAULT User-Password =~ /^cashu[AB]/
    Auth-Type := Accept,
    Exec-Program-Wait = "/usr/local/bin/tollgate-auth-radius '%{User-Name}' '%{Calling-Station-Id}' '%{User-Password}'"

# LNURLw in username
DEFAULT User-Name =~ /^lnurlw/
    Auth-Type := Accept,
    Exec-Program-Wait = "/usr/local/bin/tollgate-auth-radius '%{User-Name}' '%{Calling-Station-Id}' '%{User-Password}'"

DEFAULT User-Name =~ /^LNURLW/
    Auth-Type := Accept,
    Exec-Program-Wait = "/usr/local/bin/tollgate-auth-radius '%{User-Name}' '%{Calling-Station-Id}' '%{User-Password}'"

# LNURLw in password
DEFAULT User-Password =~ /^lnurlw/
    Auth-Type := Accept,
    Exec-Program-Wait = "/usr/local/bin/tollgate-auth-radius '%{User-Name}' '%{Calling-Station-Id}' '%{User-Password}'"

DEFAULT User-Password =~ /^LNURLW/
    Auth-Type := Accept,
    Exec-Program-Wait = "/usr/local/bin/tollgate-auth-radius '%{User-Name}' '%{Calling-Station-Id}' '%{User-Password}'"

# Reject everything else
DEFAULT
    Auth-Type := Reject
