# /etc/freeradius/3.0/sites-available/radsec
# RadSec (RADIUS over TLS) — RFC 6614
# Encrypts the entire RADIUS conversation between NAS and server.
# Uses Let's Encrypt cert for nodns.shop synced from Caddy via systemd timer.
# Runs alongside UDP 1812 (plain RADIUS with shared secret).

server radsec {
	listen {
		type = auth
		ipaddr = *
		port = 2083
		proto = tcp

		tls {
			private_key_file = /etc/freeradius/3.0/certs/letsencrypt/nodns.shop.key
			certificate_file = /etc/freeradius/3.0/certs/letsencrypt/nodns.shop.crt
			ca_file = /etc/freeradius/3.0/certs/letsencrypt/nodns.shop.crt
			fragment_size = 1024
			tls_min_version = "1.2"
			tls_max_version = "1.3"
		}
	}

	authorize {
		eap {
			ok = return
		}
		cashu-payment
		files
		-realm
		-sql
		-ldap
		expiration
		logintime
		pap
	}

	authenticate {
		Auth-Type PAP {
			pap
		}
		Auth-Type MS-CHAP {
			mschap
		}
		eap
	}

	session {
	}

	post-auth {
	}
}
