# /etc/freeradius/3.0/mods-available/cashu-exec
# FreeRADIUS exec module that calls tollgate-auth-radius for token validation.
#
# FreeRADIUS passes:
#   %{User-Name}          = inner username (Cashu token for PEAP path)
#   %{User-Password}      = inner password  (Cashu token for TTLS+PAP path)
#   %{Calling-Station-Id} = client MAC address (e.g. "aa-bb-cc-dd-ee-ff")
#
# The binary checks username OR password for a payment credential.
# Exits 0 (Accept) or 1 (Reject).
# Stdout is parsed as RADIUS attribute pairs (e.g. Reply-Message = "...")
# and added to the Access-Accept response for the NAS/captive portal.

# Uses /bin/sh wrapper to inject env vars (FreeRADIUS exec doesn't inherit
# systemd EnvironmentFile). TOLLGATE_API_KEY is the session daemon write key.

exec cashu-auth {
    wait = yes
    program = "/bin/sh -c 'TOLLGATE_AUTH_MODE=local /usr/local/bin/tollgate-auth-radius \"%{User-Name}\" \"%{Calling-Station-Id}\" \"%{User-Password}\" \"%{Cleartext-Password}\"'"
    output_pairs = reply
    timeout = 15
}
