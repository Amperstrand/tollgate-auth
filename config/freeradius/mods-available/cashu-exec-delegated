# /etc/freeradius/3.0/mods-available/cashu-exec-delegated
# Delegated mode: forwards token to tollgate-rs (tollgate-net:2121) for redemption.
# Routes here when User-Name starts with "ci-delegated" (see inner-tunnel routing).

# Secrets (nsec, API key) are sourced from /etc/tollgate/secrets.env
# which is NOT stored in version control. See Makefile deploy-radius-config.

exec cashu-auth-delegated {
    wait = yes
    program = "/bin/sh -c '. /etc/tollgate/secrets.env && TOLLGATE_AUTH_MODE=delegated TOLLGATE_SESSIOND_URL=http://127.0.0.1:2121 /usr/local/bin/tollgate-auth-radius \"%{User-Name}\" \"%{Calling-Station-Id}\" \"%{User-Password}\" \"%{Cleartext-Password}\"'"
    output_pairs = reply
    timeout = 15
}
