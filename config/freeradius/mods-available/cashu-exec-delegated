# /etc/freeradius/3.0/mods-available/cashu-exec-delegated
# Delegated mode: forwards token to tollgate-rs (tollgate-net:2121) for redemption.
# Routes here when User-Name starts with "ci-delegated" (see inner-tunnel routing).

exec cashu-auth-delegated {
    wait = yes
    program = "/bin/sh -c 'TOLLGATE_AUTH_MODE=delegated TOLLGATE_SESSIOND_URL=http://127.0.0.1:2121 TOLLGATE_API_KEY=CHANGE_ME /usr/local/bin/tollgate-auth-radius \"%{User-Name}\" \"%{Calling-Station-Id}\" \"%{User-Password}\" \"%{Cleartext-Password}\"'"
    output_pairs = reply
    timeout = 15
}
